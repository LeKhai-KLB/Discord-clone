{
  "compilerOptions": {
    "target": "ES5",
    "module": "CommonJS",
    "allowJs": false,
    "strict": true,
    "rootDir": "src",
    "outDir": "build",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "removeComments": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
